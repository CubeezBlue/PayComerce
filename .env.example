# Copiá este archivo como .env (o cargá estas variables en el panel de Hostinger)

# Carpeta persistente para las bases de datos de los comercios (fuera del código)
DATA_DIR=/home/USUARIO/paycomerce-data

# Carpeta persistente para las imágenes subidas
UPLOAD_DIR=/home/USUARIO/paycomerce-uploads

# Frase secreta y larga para firmar las sesiones del panel (¡CAMBIALA!)
AUTH_SECRET=cambia-esto-por-una-frase-larga-y-secreta

# Contraseña del PANEL DE DUEÑO (super-admin en /owner para ver todas las tiendas).
# Si la dejás vacía o no la ponés, el panel de dueño queda deshabilitado.
OWNER_PASSWORD=cambia-esta-clave-de-dueno

# Envío de emails (recuperación de contraseña) vía Resend (resend.com).
# API key de resend.com y remitente verificado. Sin esto, no se envían emails.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=PayComerce <no-reply@paycomerce.com>

# Mercado Pago OAuth (botón "Conectar con Mercado Pago"). Credenciales de TU app
# en mercadopago.com.ar/developers. Redirect URI a registrar en la app:
#   https://paycomerce.com/api/mercadopago/oauth/callback
MP_CLIENT_ID=xxxxxxxxxxxxxxxx
MP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Cobro de la SUSCRIPCIÓN del SaaS (PayComerce le cobra la mensualidad al comercio).
# Access Token de PRODUCCIÓN de la cuenta de MP de PayComerce.
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx

# Puerto (Hostinger normalmente lo asigna solo)
# PORT=3000
# HOSTNAME=0.0.0.0

# Nivel mínimo de logs: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Backups: carpeta persistente FUERA del app dir donde se guardan los .tar.gz
# (rotados). BACKUP_KEEP = cuántos conservar. Usados por scripts/backup.mjs.
BACKUP_DIR=/home/USUARIO/paycomerce-backups
BACKUP_KEEP=14

# Token secreto para el endpoint de avisos por email (/api/cron/emails).
# Poné el MISMO valor como secret CRON_SECRET en GitHub (workflow emails.yml).
CRON_SECRET=
